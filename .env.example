APP_ENV=dev
APP_NAME=Agent Approvals Backend API
API_V1_PREFIX=/api/v1
JWT_SECRET_KEY=replace-with-32-plus-character-secret
JWT_ALGORITHM=HS256
JWT_EXPIRES_MINUTES=1440
CORS_ALLOW_ORIGINS=http://127.0.0.1:3000,http://localhost:3000
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
MONGO_URI=mongodb://localhost:27017
MONGO_DB=aa_dev
MONGO_MOCK=false
WEB_PUSH_VAPID_PRIVATE_KEY=./secrets/vapid_private_key.pem
WEB_PUSH_VAPID_PUBLIC_KEY=
WEB_PUSH_SUBJECT=mailto:alerts@example.com
MAIL_TRANSPORT=smtp
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_FROM=Agent Approvals <no-reply@aa.local>
WEB_APP_URL=http://localhost:3000
